{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://ecomm-backend-rxxp.onrender.com/api/$1" },
    { "source": "/uploads/(.*)", "destination": "https://ecomm-backend-rxxp.onrender.com/uploads/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
